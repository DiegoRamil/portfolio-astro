---
import Layout from "@/layouts/layout.astro";
---

<Layout
  title="404 - Page not found | Diego Ramil Alvarez"
  description="The requested page could not be found on the official Diego Ramil Alvarez portfolio."
  robots="noindex, follow"
  canonicalUrl={null}
  includeProfileSchema={false}
>
  <main class="p-4 bg-black text-green-500 min-h-screen">
    <div class="mb-4 flex items-center" aria-hidden="true">
      <span class="w-3 h-3 rounded-full bg-red-500 mr-2"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500 mr-2"></span>
      <span class="w-3 h-3 rounded-full bg-green-500"></span>
    </div>

    <section class="px-4 max-w-3xl" aria-labelledby="not-found-title">
      <p class="text-blue-500" aria-hidden="true">cat 404.txt</p>
      <h1 id="not-found-title" class="text-2xl md:text-4xl text-green-400 font-bold">404 - Page not found</h1>
      <p class="mt-4 text-green-300 leading-relaxed">
        This URL does not exist on diegoramil.com. Return to the official portfolio homepage to find
        Diego Ramil Alvarez's experience, projects, certifications and contact links.
      </p>
      <p class="mt-6">
        <a class="text-indigo-400 border-indigo-400 border-b-2" href="/">Return to homepage</a>
      </p>
    </section>
  </main>
</Layout>
